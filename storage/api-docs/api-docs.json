    "components": {
        "schemas": {
            "ProdutoPayload": {
                "required": [
                    "NOME",
                    "PRECO",
                    "departamento_id",
                    "grupo_id"
                ],
                "properties": {
                    "CODIGO": {
                        "type": "string",
                        "maxLength": 14
                    },
                    "NOME": {
                        "type": "string"
                    },
                    "PRECO": {
                        "type": "number",
                        "format": "float"
                    },
                    "OFERTA": {
                        "type": "number",
                        "format": "float",
                        "nullable": true
                    },
                    "IMG": {
                        "type": "string",
                        "format": "uri",
                        "nullable": true
                    },
                    "departamento_id": {
                        "type": "integer"
                    },
                    "grupo_id": {
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "EmpresaLoginPayload": {
                "properties": {
                    "cnpj": {
                        "type": "string",
                        "example": "12345678000199"
                    },
                    "cnpj_cpf": {
                        "type": "string",
                        "example": "12345678000199"
                    },
                    "senha": {
                        "type": "string",
                        "example": "senha_da_empresa"
                    },
                    "chave": {
                        "type": "string",
                        "example": "senha_da_empresa"
                    }
                },
                "type": "object",
                "anyOf": [
                    {
                        "required": [
                            "cnpj",
                            "senha"
                        ]
                    },
                    {
                        "required": [
                            "cnpj",
                            "chave"
                        ]
                    },
                    {
                        "required": [
                            "cnpj_cpf",
                            "senha"
                        ]
                    },
                    {
                        "required": [
                            "cnpj_cpf",
                            "chave"
                        ]
                    }
                ]
            },
            "TvActivationCodePayload": {
                "required": [
                    "device_uuid"
                ],
                "properties": {
                    "device_uuid": {
                        "type": "string",
                        "example": "9f23edc7-9a60-4f18-bf4b-29f5d71b7030"
                    }
                },
                "type": "object"
            },
            "TvCheckActivationPayload": {
                "required": [
                    "device_uuid"
                ],
                "properties": {
                    "device_uuid": {
                        "type": "string",
                        "example": "9f23edc7-9a60-4f18-bf4b-29f5d71b7030"
                    }
                },
                "type": "object"
            },
            "TvHeartbeatPayload": {
                "properties": {
                    "token": {
                        "type": "string",
                        "example": "TOKEN_DA_TV",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "AdminActivateDevicePayload": {
                "required": [
                    "code",
                    "empresa_id",
                    "nome_tv"
                ],
                "properties": {
                    "code": {
                        "type": "string",
                        "example": "84721"
                    },
                    "empresa_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nome_tv": {
                        "type": "string",
                        "example": "TV Açougue"
                    },
                    "local": {
                        "type": "string",
                        "example": "Setor Açougue",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "CompanyBearer": {
                "type": "http",
                "bearerFormat": "Token",
                "scheme": "bearer"
            },
            "DeviceBearer": {
                "type": "http",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
